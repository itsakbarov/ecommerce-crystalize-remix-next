{
    "name": "crystallize-furniture-v3-remix-alpha",
    "private": true,
    "description": "Crystallize Furniture v3 Remix Alpha",
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "scripts": {
        "build": "npm run build:css && vite build",
        "build:css": "tailwindcss -c tailwind.config.js -m -i ./src/styles/index.css -o ./src/styles/tailwind.css",
        "dev": "concurrently \"npm run dev:css\" \"vite\"",
        "dev:css": "tailwindcss -c tailwind.config.js -w -i ./src/styles/index.css -o ./src/styles/tailwind.css",
        "start": "tsx ./server.ts",
        "dev": "tsx watch ./server.ts",
        "test": "remix-test",
        "playwright:install": "playwright install",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@adyen/adyen-web": "^5.36.0",
        "@crystallize/js-api-client": "^3.1.1",
        "@crystallize/js-storefrontaware-utils": "^3.0.0",
        "@crystallize/node-service-api-request-handlers": "^4.2.0",
        "@dintero/checkout-web-sdk": "^0.6.3",
        "@sendgrid/mail": "^7.7.0",
        "@stripe/stripe-js": "^1.46.0",
        "isbot": "^3.6.5",
        "json-to-graphql-query": "^2.2.5",
        "jsonwebtoken": "^9",
        "jwt-decode": "^3.1.2",
        "mjml": "^4.13.0",
        "nodemailer": "^6.8",
        "platformsh-config": "^2.4.1",
        "razorpay": "^2.8.4",
        "redis": "^4.5.1",
        "remix": "^3.0.0-alpha.5",
        "sharp": "^0.31.2",
        "uuid": "^9",
        "zod": "^3.20.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.28.1",
        "@types/jsonwebtoken": "^9",
        "@types/mjml": "^4.7.0",
        "@types/node": "^20.0.0",
        "@types/nodemailer": "^6.4.6",
        "@types/sharp": "^0.31",
        "@types/uuid": "^9",
        "autoprefixer": "^10.4.17",
        "concurrently": "^7.6",
        "postcss": "^8.4.20",
        "tailwindcss": "^3.4.1",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3",
        "vite": "^6.0.0"
    },
    "engines": {
        "node": ">=20"
    },
    "volta": {
        "node": "20.11.0"
    }
}
